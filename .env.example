# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}
APP_NAME=yapindo-task-management

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
# Comma-separated list of allowed origins. Required in production;
# if unset, all origins are allowed in development and none in production.
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

#--------------------------------------------------------------------
# Database (PostgreSQL)
#--------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=yapindo_task_management

JWT_SECRET=
JWT_EXPIRES_IN=1d
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
