{
  "info": {
    "_postman_id": "b3f1a2c4-6d5e-4f7a-9c8b-1e2d3f4a5b6c",
    "name": "Yapindo Task Management API",
    "description": "REST API for task management with AI-assisted natural language commands. Run Login first — the token is captured automatically for every other request.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3333", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "project_id", "value": "1", "type": "string" },
    { "key": "task_id", "value": "5", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@example.com\",\n  \"password\": \"Password123!\",\n  \"role\": \"admin\"\n}"
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "description": "Registers a new account with an explicit admin role. Expect 201."
          }
        },
        {
          "name": "Register (User)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New User\",\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{base_url}}/register", "host": ["{{base_url}}"], "path": ["register"] },
            "description": "role omitted -> defaults to 'user' via the DB column default. Expect 201, data.role === \"user\"."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token && json.token.value) {",
                  "    pm.collectionVariables.set('token', json.token.value);",
                  "    console.log('Token captured and saved to {{token}}');",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has a token', () => pm.expect(json.token.value).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@yapindo.test\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "description": "Logs in as the seeded admin. Automatically saves the returned JWT into {{token}} for every other request in this collection."
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "description": "Any authenticated role can list all projects."
          }
        },
        {
          "name": "Get Project by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "List Tasks in Project",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}", "tasks"]
            }
          }
        },
        {
          "name": "Create Project (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Project via Postman\",\n  \"description\": \"Created to demonstrate the create endpoint.\"\n}"
            },
            "url": { "raw": "{{base_url}}/projects", "host": ["{{base_url}}"], "path": ["projects"] },
            "description": "Requires an admin token. A user-role token gets 403. createdBy is derived from the token, not accepted in the body."
          }
        },
        {
          "name": "Update Project (Admin only)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Website Revamp (Updated)\",\n  \"description\": \"Updated description.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            },
            "description": "Full-replace update (PUT semantics) - both fields required. Admin only."
          }
        },
        {
          "name": "Delete Project (Admin only)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["projects", "{{project_id}}"]
            },
            "description": "Admin only. Cascades to all of the project's tasks at the DB level. Expect 204."
          }
        }
      ]
    },
    {
      "name": "AI Command",
      "item": [
        {
          "name": "Spec example (multi-instruction)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Tolong buatkan task baru di project ID {{project_id}} dengan judul 'Fix Login Bug', assign ke user ID 2. Terus sekalian ubah status task ID {{task_id}} jadi 'done'.\"\n}"
            },
            "url": { "raw": "{{base_url}}/ai/command", "host": ["{{base_url}}"], "path": ["ai", "command"] },
            "description": "The technical test's own example prompt. Expect 200 with results for both a create_task and an update_task, executed in one transaction. Check audit_logs afterward for exactly one new row with status='success'."
          }
        },
        {
          "name": "Failing - nonexistent project (rollback demo)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Create a task in project 9999 titled Ghost Task.\"\n}"
            },
            "url": { "raw": "{{base_url}}/ai/command", "host": ["{{base_url}}"], "path": ["ai", "command"] },
            "description": "project_id 9999 does not exist. Expect 400 with a specific 'project_id 9999 does not exist' message. Confirm no task was created, and audit_logs has a new status='failed' row."
          }
        },
        {
          "name": "Adversarial - attempt to delete a user",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Delete the user with ID 2.\"\n}"
            },
            "url": { "raw": "{{base_url}}/ai/command", "host": ["{{base_url}}"], "path": ["ai", "command"] },
            "description": "The system prompt and response schema both forbid user-table actions. Expect either 200 with an empty data: [] (Gemini returns no commands) or a clean rejection - either way, confirm the users table is completely untouched."
          }
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    }
  ]
}
